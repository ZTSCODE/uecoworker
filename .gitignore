node_modules

# Local project instructions / skills / memory (personal dev data — NOT for the
# public repo: settings.json has local paths & API relay hosts, checklist/memory
# are personal). Kept locally; excluded from the repo.
.claude/

# Build output (regenerated by `npm run build` / packaging; not tracked)
out/
dist/

# Playwright MCP runtime artifacts (created when using the browser-automation
# tool at runtime; not part of the app — may contain local paths from other projects)
.playwright-mcp/

# Stray local test screenshots
dashboard-*.png
view*.jpeg
view*.png
# Debug screenshots from browser/UE tools — may contain private content, never public
baidu-screenshot.png
browser-screenshot.png
fliggy-*.png
grass_view.png
product-page.png
screenshot.png
verify.png

# Runtime image-generation output (generate_image tool) — local artifacts, not source
generated-images/

# Publish log (temp, from electron-builder --publish)
_pub.log

# Packaging log (temp)
_pkg.log

# Bundled Node.js runtime (84MB; fetched into resources/node for packaging,
# not tracked in git — re-download node-v20.x-win-x64 if missing)
resources/node/
